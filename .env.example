# Local-only defaults for this workspace.
# Copy to .env.local and fill real values.
# Recommended environment mapping:
# - local .env.local -> curiosity-dev
# - Vercel preview   -> curiosity-preview
# - Vercel prod      -> curiosity-prod

# Used by server-side function (/api/spark) in deployed environments.
OPENAI_API_KEY=your-openai-api-key
# Server logging level: debug | info | warn | error | none
# Default: debug (non-production), error (production)
LOG_LEVEL=info

# Supabase browser client (required for Google auth + child profiles)
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Set to true to force local Vite traffic through /api/spark so you can
# test the full cache path with `npm run dev:web` + `npm run dev:api`.
VITE_USE_LOCAL_PROXY=false
# Browser logging level: debug | info | warn | error | none
# Default: debug (dev), error (prod)
VITE_LOG_LEVEL=debug

# Which experience should load at root `/`:
# - classic (fixed topic cards)
# - curious (open-ended Wonder Engine)
VITE_MAIN_EXPERIENCE=classic

# Optional explicit OAuth callback origin to avoid redirecting to stale preview URLs.
# If empty, app uses current browser origin.
VITE_AUTH_REDIRECT_URL=

# Postgres (Supabase) connection used by serverless cache logic.
# Keep each deployment tier on its own Supabase project.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Optional IPv4-friendly pooler connection for local/serverless environments.
# Prefer this over DATABASE_URL when your network cannot reach Supabase's
# direct IPv6-only database host. Recommended for Vercel preview/prod too.
DATABASE_POOLER_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Cache feature switches
CACHE_ENABLED=true
# Toggle DB cache reads on/off manually. Writes continue regardless.
CACHE_READ_ENABLED=false
# Keep semantic lookup off the critical path by default (exact lookup only).
# Set true to restore exact->semantic->OpenAI behavior.
CACHE_SEMANTIC_ON_PATH=false
# Store cache entries asynchronously after response for lower latency.
# Default behavior is synchronous (safer for local/dev verification).
# Set true to opt in to async store.
CACHE_ASYNC_STORE=false
# Optional detailed timing logs for cache lookup/store and /api/spark.
# In local dev these logs are already enabled by default.
CACHE_TIMING_LOGS=false
CACHE_THRESHOLD_FAST=0.92
CACHE_THRESHOLD_DEEP=0.90
CACHE_THRESHOLD_BOUNCER=0.98
CACHE_TTL_FAST_HOURS=168
CACHE_TTL_DEEP_HOURS=72
CACHE_TTL_BOUNCER_HOURS=720
PROMPT_VERSION_FAST=v1
PROMPT_VERSION_DEEP=v1
PROMPT_VERSION_BOUNCER=v1
# Prompt template resolution mode:
# - disabled: local bundled prompts only (fastest, no DB read)
# - fallback: local first, DB only if local key missing
# - preferred: DB first, then local fallback
PROMPTS_DB_MODE=disabled
# Legacy toggle (kept for backward compatibility if PROMPTS_DB_MODE is unset)
PROMPTS_DB_ENABLED=false
# In-memory cache TTL for resolved prompt templates (ms)
PROMPT_TEMPLATE_CACHE_TTL_MS=3600000

# Local API hardening toggles (default off so preview/prod behavior is unchanged until rollout)
API_AUTH_ENABLED=false
API_RATE_LIMIT_ENABLED=false
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=30

# /api/spark request hardening controls
OPENAI_ALLOWED_MODELS=gpt-4.1-mini
OPENAI_SERVER_MODEL=gpt-4.1-mini
OPENAI_MAX_REQUEST_BYTES=60000
OPENAI_MAX_MESSAGE_COUNT=20
OPENAI_MAX_MESSAGE_CHARS=4000
OPENAI_MAX_COMPLETION_TOKENS=700

# Demo ask endpoint controls (temporary tuning for local testing)
DEMO_ASK_IP_WINDOW_MS=600000
DEMO_ASK_IP_MAX=60
DEMO_ASK_SESSION_TTL_MS=86400000
DEMO_ASK_SESSION_MAX_ASKS=20

# Subscription and billing (Stripe)
FREE_DAILY_QUESTION_LIMIT=10
APP_BASE_URL=http://localhost:5173
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_MONTHLY_699=price_xxx
