# Local-only defaults for this workspace.
# Copy to .env.local and fill real values.
# Recommended environment mapping:
# - local .env.local -> curiosity-dev
# - Vercel preview   -> curiosity-preview
# - Vercel prod      -> curiosity-prod

# Used by server-side function (/api/spark) in deployed environments.
OPENAI_API_KEY=your-openai-api-key

# Optional local Vite fallback for `npm run dev` only.
# Avoid this in production environments.
VITE_OPENAI_API_KEY=your-openai-api-key

# Set to true to force local Vite traffic through /api/spark so you can
# test the full cache path with `npm run dev:web` + `npm run dev:api`.
VITE_USE_LOCAL_PROXY=false

# Postgres (Supabase) connection used by serverless cache logic.
# Keep each deployment tier on its own Supabase project.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Optional IPv4-friendly pooler connection for local/serverless environments.
# Prefer this over DATABASE_URL when your network cannot reach Supabase's
# direct IPv6-only database host. Recommended for Vercel preview/prod too.
DATABASE_POOLER_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Cache feature switches
CACHE_ENABLED=true
# Toggle DB cache reads on/off manually. Writes continue regardless.
CACHE_READ_ENABLED=false
# Keep semantic lookup off the critical path by default (exact lookup only).
# Set true to restore exact->semantic->OpenAI behavior.
CACHE_SEMANTIC_ON_PATH=false
# Store cache entries asynchronously after response for lower latency.
# Default behavior is synchronous (safer for local/dev verification).
# Set true to opt in to async store.
CACHE_ASYNC_STORE=false
# Optional detailed timing logs for cache lookup/store and /api/spark.
# In local dev these logs are already enabled by default.
CACHE_TIMING_LOGS=false
CACHE_THRESHOLD_FAST=0.92
CACHE_THRESHOLD_DEEP=0.90
CACHE_THRESHOLD_BOUNCER=0.98
CACHE_TTL_FAST_HOURS=168
CACHE_TTL_DEEP_HOURS=72
CACHE_TTL_BOUNCER_HOURS=720
PROMPT_VERSION_FAST=v1
PROMPT_VERSION_DEEP=v1
PROMPT_VERSION_BOUNCER=v1
